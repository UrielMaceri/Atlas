<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Typography ───────────────────────────────────── -->

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.empty-state">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="#777777" />
    </Style>

    <!-- ── Cards ────────────────────────────────────────── -->

    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="#000000" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="#ffffff" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.content-card">
        <Setter Property="Background" Value="#424242" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="#424242" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="220" />
    </Style>

    <Style Selector="Border.workspace-card">
        <Setter Property="Background" Value="#2a2a2a" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderBrush" Value="#3a3a3a" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.workspace-card:pointerover">
        <Setter Property="Background" Value="#333333" />
        <Setter Property="BorderBrush" Value="#555555" />
    </Style>

    <!-- ── Buttons (general) ────────────────────────────── -->

    <Style Selector="Button.action-button">
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="#333333" />
        <Setter Property="Foreground" Value="#cccccc" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.action-button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#444444" />
    </Style>

    <!-- Transparent button used as clickable card area -->
    <Style Selector="Button.card-open-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.card-open-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Small icon button -->
    <Style Selector="Button.icon-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="#999999" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3a3a3a" />
    </Style>
    <Style Selector="Button.icon-btn PathIcon">
        <Setter Property="Foreground" Value="#999999" />
    </Style>
    <Style Selector="Button.icon-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#dddddd" />
    </Style>

    <!-- Danger variant (delete) -->
    <Style Selector="Button.danger-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#4a1a1a" />
    </Style>
    <Style Selector="Button.danger-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#ff6b6b" />
    </Style>

    <!-- ── Custom tab strip ─────────────────────────────── -->

    <!-- Wrapper border for each workspace tab -->
    <Style Selector="Border.tab-container">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Border.tab-container:pointerover">
        <Setter Property="Background" Value="#222222" />
    </Style>
    <Style Selector="Border.tab-selected">
        <Setter Property="Background" Value="#2a2a2a" />
        <Setter Property="BorderBrush" Value="#3a3a3a" />
        <Setter Property="BorderThickness" Value="1,1,1,0" />
    </Style>

    <!-- Tab button (home icon / workspace name) -->
    <Style Selector="Button.tab-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Foreground" Value="#aaaaaa" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#222222" />
    </Style>
    <Style Selector="Button.tab-selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#2a2a2a" />
    </Style>
    <Style Selector="Button.tab-selected">
        <Setter Property="Foreground" Value="#ffffff" />
    </Style>

    <!-- Workspace name button inside the tab container -->
    <Style Selector="Button.tab-title-btn">
        <Setter Property="Padding" Value="8,6,4,6" />
        <Setter Property="MinWidth" Value="60" />
        <Setter Property="MaxWidth" Value="160" />
    </Style>

    <!-- × close button inside tab -->
    <Style Selector="Button.tab-close-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2,0,6,0" />
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.tab-close-btn:pointerover">
        <Setter Property="Foreground" Value="#ff6b6b" />
    </Style>

    <!-- + add tab button -->
    <Style Selector="Button.tab-add-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab-add-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#222222" />
    </Style>
    <Style Selector="Button.tab-add-btn:pointerover">
        <Setter Property="Foreground" Value="#ffffff" />
    </Style>

    <!-- Inline rename TextBox inside a tab -->
    <Style Selector="TextBox.tab-rename-box">
        <Setter Property="Background" Value="#333333" />
        <Setter Property="Foreground" Value="#ffffff" />
        <Setter Property="BorderBrush" Value="#555555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- TextBox inside workspace/home cards -->
    <Style Selector="TextBox.card-input">
        <Setter Property="Background" Value="#1e1e1e" />
        <Setter Property="Foreground" Value="#dddddd" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Inline rename in workspace header -->
    <Style Selector="TextBox.inline-rename">
        <Setter Property="Background" Value="#252525" />
        <Setter Property="Foreground" Value="#ffffff" />
        <Setter Property="BorderBrush" Value="#555555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</Styles>
