<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="#000000" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="#ffffff" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.action-button">
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style Selector="Border.content-card">
        <Setter Property="Background" Value="#424242" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="#424242" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="220" />
    </Style>

    <Style Selector="TextBlock.empty-state">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="#777777" />
    </Style>

    <!-- Workspace card in Home -->
    <Style Selector="Border.workspace-card">
        <Setter Property="Background" Value="#2a2a2a" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderBrush" Value="#3a3a3a" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.workspace-card:pointerover">
        <Setter Property="Background" Value="#333333" />
        <Setter Property="BorderBrush" Value="#555555" />
    </Style>

    <!-- TabControl win11 style -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="#1a1a1a" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Foreground" Value="#aaaaaa" />
        <Setter Property="Background" Value="Transparent" />
        <!-- <Setter Property="CornerRadius" Value="8,8,0,0" /> -->
    </Style>

    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="#ffffff" />
        <Setter Property="Background" Value="#2a2a2a" />
    </Style>

    <Style Selector="TabItem:pointerover">
        <Setter Property="Foreground" Value="#dddddd" />
        <Setter Property="Background" Value="#222222" />
    </Style>

</Styles>